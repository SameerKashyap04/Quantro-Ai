# Quantro Personal AI - Environment Configuration

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-jwt-key-change-in-production

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://quantro:secretpassword@db:5432/quantro_db
# For local dev without docker use: postgresql+asyncpg://user:pass@localhost:5432/quantro_db

# Cache (Redis)
REDIS_URL=redis://redis:6379/0

# Trading Settings
TRADING_MODE=paper # paper | approval | auto
RISK_MAX_DRAWDOWN_PCT=5.0
RISK_MAX_PER_TRADE_PCT=2.0

# Broker API Keys (Groww / Zerodha etc.)
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ENV=sandbox

